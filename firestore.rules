rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: Can read anyone's profile, but only create/update their own.
    match /users/{userId} {
      allow read: if true;
      allow create, update: if request.auth != null && request.auth.uid == userId;
    }

    // Blogs:
    match /blogs/{blogId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow delete: if request.auth != null && resource.data.author_id == request.auth.uid;
      
      // Rule 1: Author can update any field
      allow update: if request.auth != null && resource.data.author_id == request.auth.uid;
      
      // Rule 2: Any authenticated user can update *only* the 'likes' field
      allow update: if request.auth != null && 
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes']);
                      
      // Rule 3: Anyone (even unauthenticated) can update *only* the 'views' field,
      // and only if it's incrementing by 1.
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views']) &&
                      request.resource.data.views == resource.data.views + 1;
    }

    // Comments: Can read any, create if logged in, update/delete only their own.
    match /comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && resource.data.user_id == request.auth.uid;
    }

    // Reading Lists: A user can manage their own lists
    match /reading_lists/{listId} {
      allow read, create, update, delete: if request.auth != null && (
        (resource == null && request.resource.data.user_id == request.auth.uid) || 
        (resource != null && resource.data.user_id == request.auth.uid)
      );
    }

    // Notifications: Users can read/update their own notifications; any logged-in user can create them (for mentions/replies).
    match /notifications/{notificationId} {
      allow read, update, delete: if request.auth != null && resource.data.recipient_id == request.auth.uid;
      allow create: if request.auth != null;
    }

    // Contacts: Anyone can create, but only admins can read or delete.
    match /contacts/{contactId} {
      allow read, delete: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      allow create: if true;
      allow update: if false;
    }
  }
}